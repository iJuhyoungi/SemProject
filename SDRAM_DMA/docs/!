## 4. 메인 소스 코드 (`main.c`)

```c
#include <stdint.h>

/* 레지스터 매크로 */
#define CCM_CCGR1                               (*(volatile uint32_t *)0x400FC06C)
#define IOMUXC_SW_MUX_CTL_PAD_GPIO_AD_B0_05     (*(volatile uint32_t *)0x401F80D0)
#define GPIO1_GDIR                              (*(volatile uint32_t *)0x401B8004)
#define GPIO1_DR                                (*(volatile uint32_t *)0x401B8000)
#define CCM_CBCMR                               (*(volatile uint32_t *)0x400FC018)
#define CCM_CBCDR                               (*(volatile uint32_t *)0x400FC014)
#define CCM_CDHIPR                              (*(volatile uint32_t *)0x400FC048)

/* 132MHz 클럭 설정 함수 (RAM 대피 & 정석 스위칭) */
__attribute__((section(".data"))) void Clock_Init_132MHz(void) {
    /* 1. 우회로(Bypass)로 스위치 돌림: 클럭 스위칭 중 시스템 뻗음 방지 */
    CCM_CBCDR |= (1 << 25); // PERIPH_CLK_SEL = 1 (대체 클럭 사용)
    while (CCM_CDHIPR & (1 << 5)); // 스위칭 완료 대기

    /* 2. 안전하게 4분주 기어 장착 (AHB_PODF = 3) -> 528 / 4 = 132MHz */
    CCM_CBCDR &= ~(7 << 10); 
    CCM_CBCDR |= (3 << 10);  
    while (CCM_CDHIPR & (1 << 1)); // 변경 완료 대기

    /* 3. 메인 클럭 소스를 528MHz Sys PLL로 설정 (PRE_PERIPH_CLK_SEL = 00) */
    CCM_CBCMR &= ~(3 << 18); 

    /* 4. 메인 경로로 다시 복귀 (PERIPH_CLK_SEL = 0) */
    CCM_CBCDR &= ~(1 << 25); 
    while (CCM_CDHIPR & (1 << 5)); // 스위칭 완료 대기
}

/* RAM 지연 함수 */
__attribute__((section(".data"))) void delay_loop(uint32_t count) {
    for (volatile uint32_t i = 0; i < count; i++) {
        __asm("nop"); 
    }
}

/* RAM 메인 함수 */
__attribute__((section(".data"))) int main(void)
{
    /* 초기 지연 (디버거 접속용) */
    delay_loop(2000000);

    /* 🚀 132MHz로 안전하게 스위칭 */
    Clock_Init_132MHz();        

    /* GPIO 및 클럭 활성화 */
    CCM_CCGR1 |= (3 << 26); 
    IOMUXC_SW_MUX_CTL_PAD_GPIO_AD_B0_05 = 0x05; 
    GPIO1_GDIR |= (1 << 5);             

    /* 무한 루프: LED 깜빡이기 */
    while (1) {
        GPIO1_DR |= (1 << 5);   // ON (HIGH)
        
        /* 속도가 5.5배 빨라졌으므로 딜레이 카운트를 크게 증가 */
        delay_loop(10000000);    
        
        GPIO1_DR &= ~(1 << 5);  // OFF (LOW)
        delay_loop(10000000);    
    }
    return 0;
}
